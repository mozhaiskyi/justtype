{
  "manifest_version": 3,
  "name": "JustType",
  "version": "1.0.2",
  "description": "Start typing anywhere — JustType finds the right input and routes your text. No clicking. No missed shortcuts.",
  "permissions": ["storage"],
  "icons": {
    "16": "icon.ico",
    "48": "icon.ico",
    "128": "icon.ico"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
